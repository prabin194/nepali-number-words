{
  "name": "nepali-number-words",
  "version": "0.1.0",
  "description": "A lightweight, framework-independent TypeScript library for converting numbers and monetary amounts to Nepali words",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nepali",
    "number",
    "currency",
    "words",
    "devanagari",
    "nepal",
    "rupees",
    "translation"
  ],
  "author": "prabin194",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prabin194/nepali-number-words.git"
  },
  "bugs": {
    "url": "https://github.com/prabin194/nepali-number-words/issues"
  },
  "homepage": "https://github.com/prabin194/nepali-number-words#readme",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "vite": "^6.4.2"
  }
}
